# Phase 19: real deployment secrets/config — copy to .env (gitignored),
# fill in real values, never commit the filled-in file.

# Postgres superuser password — used by every service's own DATABASE_URL
# too (one instance, multiple logical databases; see
# deploy/postgres-init/01-create-databases.sql).
POSTGRES_PASSWORD=changeme

# A real target ERP database connection string, resolved by governance's
# secrets_registry.yaml (Phase 7). Read as a plain env var by
# governance/security/secrets.py today — a real Docker `secrets:`
# file-mount would need a small entrypoint wrapper this codebase doesn't
# have yet (docker-compose.yml's own comment names this honestly).
DEMO_ERP_DATABASE_URL=postgresql://user:pass@host:5432/demo_erp

# Gateway's own stub bearer-token map (Phase 2) — same file every
# service's own README already documents.
GATEWAY_TOKEN=dev-admin-token

# Phase 31: "stub" (default) keeps every prior phase's token→actor map
# unchanged. Set "oidc" for real per-user auth through services/identity/
# — Gateway, Control UI, MCP Surface, and the OpenAI shim all read this
# the same way.
AUTH_MODE=stub

# Phase 31: off by default — every prior phase's stub-auth workflow
# decides its own request as the shared "human_admin" actor; this only
# becomes meaningful once AUTH_MODE=oidc gives real, distinct per-user
# identities. Set "true" in a real team deployment.
ENFORCE_APPROVER_NOT_REQUESTER=false
